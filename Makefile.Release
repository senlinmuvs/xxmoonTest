####### Install

install_target: first FORCE
	@if not exist C:$(INSTALL_ROOT:@msyshack@%=%)\Qt\6.9.0\mingw_64\tests\xxmoonTest mkdir C:$(INSTALL_ROOT:@msyshack@%=%)\Qt\6.9.0\mingw_64\tests\xxmoonTest & if not exist C:$(INSTALL_ROOT:@msyshack@%=%)\Qt\6.9.0\mingw_64\tests\xxmoonTest exit 1
	-$(INSTALL_FILE) $(DESTDIR_TARGET) C:$(INSTALL_ROOT:@msyshack@%=%)\Qt\6.9.0\mingw_64\tests\xxmoonTest\$(TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) C:$(INSTALL_ROOT:@msyshack@%=%)\Qt\6.9.0\mingw_64\tests\xxmoonTest\$(TARGET)
	-$(DEL_DIR) C:$(INSTALL_ROOT:@msyshack@%=%)\Qt\6.9.0\mingw_64\tests\xxmoonTest 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

